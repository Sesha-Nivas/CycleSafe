# Google Maps API Key
# Get your key from: https://console.cloud.google.com/
# Add these restrictions in Google Cloud Console for security:
# - HTTP referrers: https://vercel.com/*, http://localhost:*
# - APIs: Maps JavaScript API, Geocoding API
VITE_GOOGLE_MAPS_API_KEY=your_api_key_here

# Development mode - set to false when deploying to Vercel
VITE_DEV_MODE=true
